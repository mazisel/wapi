# ============================================================
# WAPI — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve doldurun
# ============================================================

# Supabase / PostgreSQL bağlantısı
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Master API anahtarı — ilk kurulumda MUTLAKA değiştirin!
MASTER_API_KEY=wapi_master_changeme_immediately

# ---- Port yapılandırması ----
API_PORT=3000
ADMIN_PORT=3001

# ---- WebSocket URL (build sırasında bake edilir) ----
# Sunucunuzun dış IP veya domain adresi olmalı
# Örnek: ws://192.168.1.100:3000  veya  wss://wapi.sirketim.com
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ---- Rate Limiting ----
HOURLY_MSG_LIMIT=60
DAILY_MSG_LIMIT=500
MIN_MSG_GAP_MS=3000

# ---- Logging ----
LOG_LEVEL=info
