# ============================================================
# WAPI — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın, sadece 2 şeyi doldurun
# ============================================================

# PostgreSQL şifresi — istediğiniz bir şifre yazın
POSTGRES_PASSWORD=buraya_guclu_bir_sifre_yazin

# Master API anahtarı — admin paneline giriş için
MASTER_API_KEY=wapi_buraya_guclu_bir_sifre_yazin_2024

# WebSocket URL — Portainer'ın çalıştığı sunucunun IP'si veya domain'i
# Örnek: ws://192.168.1.100:3000  veya  wss://wapi.sirketim.com
NEXT_PUBLIC_WS_URL=ws://SUNUCU_IP:3000

# ── Portlar (değiştirmenize gerek yok) ───────────────────
API_PORT=3000
ADMIN_PORT=3001

# ── Rate limiting (varsayılanlar uygundur) ────────────────
HOURLY_MSG_LIMIT=60
DAILY_MSG_LIMIT=500
MIN_MSG_GAP_MS=3000

# ── Log seviyesi ──────────────────────────────────────────
LOG_LEVEL=info
